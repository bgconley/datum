# Caddy reverse proxy — single-origin entrypoint at :3080
# Routes API and WebSocket to datum-api, everything else to frontend.
# In compose, service names resolve to container IPs.
:3080 {
    handle /api/* {
        reverse_proxy datum-api:8001
    }

    handle /ws/* {
        reverse_proxy datum-api:8001
    }

    handle {
        reverse_proxy datum-frontend:3000
    }
}
