# Qwen3-Reranker Multi-Backend Service Configuration
# Copy this file to .env and customize as needed

# ============================================
# Backend Selection
# ============================================
# Options: auto | pytorch | vllm | mlx
# - auto: Auto-detect best available backend
# - pytorch: Cross-platform (CUDA/MPS/CPU) - RECOMMENDED
# - vllm: High-throughput CUDA deployment
# - mlx: Apple Silicon optimization
QWEN_RERANK_BACKEND=auto

# Profile to load from config/reranker_profiles.yaml
# PyTorch profiles: qwen3_4b_cuda, qwen3_4b_mps, qwen3_4b_cpu
# vLLM profiles: qwen3_4b_vllm, qwen3_4b_vllm_multi_gpu
# MLX profiles: qwen3_4b_mlx_fp16, qwen3_4b_mlx_8bit, qwen3_4b_mlx_4bit
QWEN_RERANK_PROFILE=qwen3_4b_cuda

# ============================================
# Service Configuration
# ============================================
QWEN_RERANK_HOST=0.0.0.0
QWEN_RERANK_PORT=9003
QWEN_RERANK_LOG_LEVEL=INFO
QWEN_RERANK_LOG_FORMAT=json

# ============================================
# PyTorch Device Override
# ============================================
# Options: auto | cuda | cuda:0 | cuda:1 | mps | cpu
# Leave unset to use profile default
# QWEN_RERANK_DEVICE=auto

# ============================================
# Model Override
# ============================================
# Override the model_id from profile
# QWEN_RERANK_MODEL_ID=Qwen/Qwen3-Reranker-4B

# ============================================
# Limits Override
# ============================================
# QWEN_RERANK_MAX_LENGTH=8192
# QWEN_RERANK_BATCH_SIZE=16
# QWEN_RERANK_MAX_CONCURRENT_FORWARDS=2

# ============================================
# vLLM-Specific Override
# ============================================
# QWEN_RERANK_TENSOR_PARALLEL_SIZE=1
# QWEN_RERANK_GPU_MEMORY_UTILIZATION=0.85

# ============================================
# Timeouts
# ============================================
QWEN_RERANK_REQUEST_TIMEOUT=120.0
QWEN_RERANK_WARMUP_TIMEOUT=300.0

# ============================================
# Model Alias Allowlist
# ============================================
# Comma-separated list of allowed model aliases in request body (optional)
# If not set, any model string is accepted
# QWEN_RERANK_MODEL_ALIAS_ALLOWLIST=Qwen/Qwen3-Reranker-4B,qwen3-reranker-4b

# ============================================
# Model Access (if needed)
# ============================================
# Uncomment if you need to access gated models
# HF_TOKEN=your_huggingface_token

# ============================================
# CUDA Memory Configuration
# ============================================
# Helps with memory fragmentation on CUDA
PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Enable MPS fallback for unsupported operations (Apple Silicon)
# PYTORCH_ENABLE_MPS_FALLBACK=1
